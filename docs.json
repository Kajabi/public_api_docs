{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Kajabi",
  "colors": {
    "primary": "#ff757a",
    "light": "#fe7279",
    "dark": "#ff757a"
  },
  "fonts": {
    "body": {
      "family": "Faire Sprig",
      "source": "https://cdn.prod.website-files.com/66aebc00ad11d5f27673a187/66aebc00ad11d5f27673a25f_FAIRE-Sprig-Regular.woff2",
      "format": "woff2"
    },
    "heading": {
      "family": "Greet",
      "source": "https://cdn.prod.website-files.com/66aebc00ad11d5f27673a187/66aebc00ad11d5f27673a1f0_Greet%20VF.woff2",
      "format": "woff2"
    },
    "family": "Inter"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#fdfdfc",
      "dark": "#0a0a0a"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "API Documentation",
        "openapi": "openapi.yaml",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["api-reference/introduction", "api-reference/authentication"]
          }
        ]
      },
      {
        "tab": "Changelog",
        "pages": ["changelog"]
      }
